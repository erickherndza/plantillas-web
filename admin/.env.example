# Renombra este archivo a .env y completa los valores antes de correr en producción.

# Clave secreta para sesiones Flask — genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# Entorno (development | production)
FLASK_ENV=development
